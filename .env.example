# Hugging Face credentials and model repo configuration
HF_TOKEN=your_huggingface_token_here
HF_MODEL_REPO=doughnut23/emollama-models
HF_REPO_TYPE=model

# Port configuration
PORT=7860

# GPU configuration (adjust to your GPU IDs if you have multiple GPUs)
CUDA_VISIBLE_DEVICES=0

# Model paths (defaults inside container, adjust if needed)
MODEL_PATH=/app/checkpoints/Llama-2-7b-chat-hf
HUBERT_PATH=/app/checkpoints/transformer/chinese-hubert-large
CKPT_PATH=/app/checkpoints/save_checkpoint/Emoation_LLaMA.pth
